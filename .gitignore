# --- Rust ---
/target
**/*.rs.bk
Cargo.lock.bak

# --- JTEC isolation (do NOT remove) ---
# Private fixtures and any local-only config that points at them.
tests/fixtures/private/
private_path.toml
*.private.*

# Any path or filename containing "jtec" (case-insensitive). Belt-and-braces
# alongside the pre-commit hook in hooks/pre-commit.
**/[Jj][Tt][Ee][Cc]*
**/*[Jj][Tt][Ee][Cc]*

# --- MASM golden oracle (tools/oracle) ---
# Local-only config holding the isolated toolchain path, and scratch run outputs.
*.private.psd1
oracle-out/
tools/oracle/_*/
tools/oracle/_*.lst
tools/oracle/_*.s19
tools/oracle/_*.obj

# Scratch diff/diagnostic outputs (hold corpus-derived listings — never commit).
out_diag/

# --- Editor / OS noise ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# RE scratch / regenerable artifacts
tools/oracle/masm_flat.bin
tools/oracle/decomp_out.txt
tools/oracle/__pycache__/
